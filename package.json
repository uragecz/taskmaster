{
  "name": "taskmaster",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @taskmaster/web dev",
    "dev:api": "pnpm --filter @taskmaster/api dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test"
  }
}
