# Empty -> the browser calls the API on the same origin (/api/*), forwarded to
# the API by the gateway (prod) or a Next.js rewrite (dev). Set an absolute URL
# only if the API lives on a different origin.
NEXT_PUBLIC_API_URL=

# Dev only: point the realtime socket straight at the API (e.g. http://localhost:4000)
# so it skips the Next.js rewrite. Leave empty in prod (connects via the proxy).
NEXT_PUBLIC_SOCKET_URL=
